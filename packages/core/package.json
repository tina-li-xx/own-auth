{
  "name": "own-auth",
  "version": "0.3.0",
  "type": "module",
  "description": "Framework-independent TypeScript auth engine with Postgres and Cloudflare D1 storage.",
  "license": "MIT",
  "author": "Tina Li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tina-li-xx/own-auth.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/tina-li-xx/own-auth/issues"
  },
  "homepage": "https://github.com/tina-li-xx/own-auth#readme",
  "keywords": [
    "auth",
    "authentication",
    "cloudflare",
    "d1",
    "postgres",
    "sessions",
    "api-keys",
    "organisations",
    "backend",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "own-auth": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "migrations",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "default": "./dist/postgres/index.js"
    },
    "./d1": {
      "types": "./dist/d1/index.d.ts",
      "default": "./dist/d1/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./passkeys": {
      "types": "./dist/passkeys-client.d.ts",
      "default": "./dist/passkeys-client.js"
    },
    "./google-one-tap": {
      "types": "./dist/google-one-tap.d.ts",
      "default": "./dist/google-one-tap.js"
    },
    "./migrations/001_initial.sql": "./migrations/001_initial.sql",
    "./migrations/002_external_providers.sql": "./migrations/002_external_providers.sql",
    "./migrations/003_oauth_transactions.sql": "./migrations/003_oauth_transactions.sql",
    "./migrations/004_mfa.sql": "./migrations/004_mfa.sql",
    "./migrations/005_oauth_credentials.sql": "./migrations/005_oauth_credentials.sql",
    "./migrations/006_passkeys.sql": "./migrations/006_passkeys.sql",
    "./migrations/007_plugin_migrations.sql": "./migrations/007_plugin_migrations.sql",
    "./migrations/d1/*.sql": "./migrations/d1/*.sql",
    "./docs/installation.md": "./docs/installation.md",
    "./docs/cloudflare-d1.md": "./docs/cloudflare-d1.md",
    "./docs/security-model.md": "./docs/security-model.md"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "pack:check": "npm pack --dry-run",
    "publish:npm": "npm publish --access public --auth-type=web",
    "test": "vitest run",
    "test:integration": "vitest run test/postgres/postgres-storage.integration.test.ts test/postgres/postgres-concurrency.integration.test.ts test/postgres/postgres-migrations.integration.test.ts",
    "test:integration:required": "OWN_AUTH_REQUIRE_POSTGRES=true vitest run test/postgres/postgres-storage.integration.test.ts test/postgres/postgres-concurrency.integration.test.ts test/postgres/postgres-migrations.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@opentelemetry/api": "1.9.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "jiti": "^2.7.0",
    "oauth4webapi": "^3.8.6",
    "otpauth": "^9.5.1",
    "pg": "^8.16.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
