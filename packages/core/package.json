{
  "name": "own-auth",
  "version": "0.1.11",
  "type": "module",
  "description": "Framework-independent TypeScript auth engine with Postgres storage.",
  "license": "MIT",
  "author": "Tina Li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tina-li-xx/own-auth.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/tina-li-xx/own-auth/issues"
  },
  "homepage": "https://github.com/tina-li-xx/own-auth#readme",
  "keywords": [
    "auth",
    "authentication",
    "postgres",
    "sessions",
    "api-keys",
    "organisations",
    "backend",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "own-auth": "dist/cli.js"
  },
  "files": [
    "dist",
    "migrations"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "default": "./dist/postgres/index.js"
    },
    "./migrations/001_initial.sql": "./migrations/001_initial.sql"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "pack:check": "npm pack --dry-run",
    "publish:npm": "npm publish --access public --auth-type=web",
    "test": "vitest run",
    "test:integration": "vitest run test/postgres/postgres-storage.integration.test.ts",
    "test:integration:required": "OWN_AUTH_REQUIRE_POSTGRES=true vitest run test/postgres/postgres-storage.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.16.3"
  }
}
