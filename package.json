{
  "name": "own-auth-workspace",
  "version": "0.3.0",
  "private": true,
  "description": "Vendor-neutral authentication platform for framework-independent auth, sessions, API keys, and organisations.",
  "type": "module",
  "license": "MIT",
  "author": "Tina Li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/own-auth/own-auth.git"
  },
  "bugs": {
    "url": "https://github.com/own-auth/own-auth/issues"
  },
  "homepage": "https://own-auth.com",
  "keywords": [
    "auth",
    "authentication",
    "cloudflare",
    "d1",
    "postgres",
    "sessions",
    "api-keys",
    "organisations",
    "backend",
    "typescript"
  ],
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "cloudflare:check": "tsx scripts/check-cloudflare-worker.ts",
    "d1-resolution:check": "node scripts/check-d1-package-resolution.mjs",
    "postgres-loading:check": "node ./scripts/check-lazy-postgres.mjs",
    "docs:check": "node scripts/sync-package-docs.mjs --check",
    "docs:sync": "node scripts/sync-package-docs.mjs",
    "release:check": "pnpm docs:check && pnpm build && pnpm postgres-loading:check && pnpm d1-resolution:check && pnpm cloudflare:check && pnpm test && pnpm --filter own-auth test:integration:required && pnpm --filter own-auth pack:check",
    "release:next": "node scripts/release.mjs publish next",
    "release:stable": "node scripts/release.mjs publish stable",
    "release:tag": "node scripts/release.mjs tag",
    "release:verify": "node scripts/release.mjs verify",
    "test": "pnpm -r test && pnpm run test:release",
    "test:release": "vitest run scripts/release.test.ts",
    "typecheck": "pnpm --filter own-auth typecheck && pnpm --filter own-auth-basic-node-example build"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "2.9.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
