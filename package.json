{
  "name": "own-auth-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "cloudflare:check": "tsx scripts/check-cloudflare-worker.ts",
    "d1-resolution:check": "node scripts/check-d1-package-resolution.mjs",
    "dpop-resolution:check": "node scripts/check-dpop-package-resolution.mjs",
    "protected-resource-resolution:check": "node scripts/check-protected-resource-package-resolution.mjs",
    "root-loading:check": "node ./scripts/check-root-package-loading.mjs",
    "saml-resolution:check": "node scripts/check-saml-package-resolution.mjs",
    "scim-resolution:check": "node scripts/check-scim-package-resolution.mjs",
    "docs:check": "node scripts/sync-package-docs.mjs --check",
    "docs:sync": "node scripts/sync-package-docs.mjs",
    "release:check": "pnpm docs:check && pnpm build && pnpm typecheck && pnpm root-loading:check && pnpm saml-resolution:check && pnpm scim-resolution:check && pnpm d1-resolution:check && pnpm dpop-resolution:check && pnpm protected-resource-resolution:check && pnpm cloudflare:check && pnpm test && pnpm --filter own-auth test:integration:required && pnpm --filter own-auth pack:check",
    "release:next": "node scripts/release.mjs publish next",
    "release:stable": "node scripts/release.mjs publish stable",
    "release:tag": "node scripts/release.mjs tag",
    "release:verify": "node scripts/release.mjs verify",
    "test": "pnpm -r test && pnpm run test:release",
    "test:release": "vitest run scripts/release.test.ts",
    "typecheck": "pnpm --filter own-auth typecheck && pnpm --filter own-auth-basic-node-example build"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "2.9.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
